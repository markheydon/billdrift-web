{
  "mcpServers": {
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "fluent-ui-blazor": {
      "command": "dnx",
      "args": [
        "Microsoft.FluentUI.AspNetCore.McpServer@5.0.0-rc.3-26138.1",
        "--yes"
      ]
    }
  }
}
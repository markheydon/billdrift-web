<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <p>Approve eligible proposal(s)?</p>
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="ConfirmAsync">Confirm</FluentButton>
        <FluentButton OnClick="CancelAsync">Cancel</FluentButton>
    </FluentStack>
</FluentStack>

@code {
    [CascadingParameter]
    public IDialogInstance Dialog { get; set; } = default!;

    private async Task ConfirmAsync() => await Dialog.CloseAsync(DialogResult.Ok(true));

    private async Task CancelAsync() => await Dialog.CloseAsync(DialogResult.Cancel());
}

@using Microsoft.FluentUI.AspNetCore.Components

<FluentInputFile Id="@InputId"
                 Mode="InputFileMode.Stream"
                 Multiple="false"
                 Accept="@Accept"
                 MaximumFileSize="@MaxFileSize"
                 Disabled="@Disabled"
                 OnFileUploaded="@OnFileUploadedAsync"
                 OnFileError="@OnFileErrorAsync"
                 Height="120px"
                 Margin="@Margin.Bottom2">
    <ChildContent>
        <label for="@InputId" style="cursor: pointer;">
            <FluentIcon Value="@(new Icons.Regular.Size20.Document())" />
        </label>
        <div>
            @if (SelectedFileName is null)
            {
                <span>Drop file or <label for="@InputId" style="cursor: pointer; text-decoration: underline;">browse</label></span>
            }
            else
            {
                <span><strong>@SelectedFileName</strong> selected</span>
            }
        </div>
        <div><em>@Hint</em></div>
    </ChildContent>
</FluentInputFile>

@code {
    private const long MaxFileSize = 25 * 1024 * 1024;

    [Parameter, EditorRequired]
    public string InputId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Accept { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Hint { get; set; } = string.Empty;

    [Parameter]
    public string? SelectedFileName { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<(byte[] Buffer, string FileName)?> OnFileSelected { get; set; }

    private async Task OnFileUploadedAsync(FluentInputFileEventArgs file)
    {
        if (file.Stream is null || file.IsCancelled)
        {
            await OnFileSelected.InvokeAsync(null);
            return;
        }

        await using var memory = new MemoryStream();
        await file.Stream.CopyToAsync(memory);
        await file.Stream.DisposeAsync();
        await OnFileSelected.InvokeAsync((memory.ToArray(), file.Name));
    }

    private Task OnFileErrorAsync(FluentInputFileErrorEventArgs args) =>
        OnFileSelected.InvokeAsync(null);
}

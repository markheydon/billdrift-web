@page "/history/{RunId:guid}"
@using BillDrift.Application.History
@using BillDrift.Domain.History
@inject IRunHistoryApiClient ApiClient
@inject IApprovalApiClient ApprovalClient
@inject NavigationManager Navigation

<PageTitle>Run Detail</PageTitle>

@if (_loading)
{
    <FluentSpinner />
}
else if (_error is not null)
{
    <FluentMessageBar Intent="MessageBarIntent.Error">@_error</FluentMessageBar>
}
else if (_detail is not null)
{
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
        <FluentButton Appearance="ButtonAppearance.Transparent" OnClick="@(() => Navigation.NavigateTo("/history"))">
            Back to list
        </FluentButton>
        <h2>Run @RunId</h2>
        <FluentBadge>@_detail.Status</FluentBadge>
    </FluentStack>

    <FluentTabs>
        <FluentTab Header="Summary">
            <p>Billing period: @_detail.BillingPeriod.Start – @_detail.BillingPeriod.End</p>
            <p>Match groups: @_detail.SummaryMetrics.MatchGroupCount</p>
            <p>Mismatches: @_detail.SummaryMetrics.MismatchCount</p>
            <p>Mapping version: @_detail.MappingVersion.VersionId</p>
        </FluentTab>
        <FluentTab Header="Inputs">
            <FluentDataGrid Items="@_detail.InputSnapshots.AsQueryable()" GridTemplateColumns="1fr 1fr 1fr 1fr">
                <PropertyColumn Title="Domain" Property="@(i => i.Domain)" />
                <PropertyColumn Title="Present" Property="@(i => i.IsPresent)" />
                <PropertyColumn Title="File" Property="@(i => i.SourceFileName)" />
                <PropertyColumn Title="Records" Property="@(i => i.RecordCount)" />
            </FluentDataGrid>
        </FluentTab>
        <FluentTab Header="Proposals">
            @if (_detail.ProposalStatusLinks.Count == 0)
            {
                <EmptyStatePanel
                    Title="No proposals in approval queue"
                    Message="Ingest reconciliation proposals to start the approval workflow." />
                <FluentButton OnClick="IngestProposalsAsync">Ingest proposals</FluentButton>
            }
            else
            {
                <FluentAnchorButton Appearance="ButtonAppearance.Transparent" Href="@($"/approvals/{RunId}")">Open approval queue</FluentAnchorButton>
                <FluentDataGrid Items="@_detail.ProposalStatusLinks.AsQueryable()" GridTemplateColumns="1fr 1fr">
                    <PropertyColumn Title="Proposal" Property="@(p => p.ProposedChangeId)" />
                    <PropertyColumn Title="Status" Property="@(p => p.DecisionState)" />
                </FluentDataGrid>
            }
        </FluentTab>
        <FluentTab Header="Exceptions">
            @if (_detail.Results?.Mismatches.Count > 0)
            {
                <FluentDataGrid Items="@_detail.Results.Mismatches.AsQueryable()" GridTemplateColumns="1fr 1fr 2fr">
                    <PropertyColumn Title="Type" Property="@(m => m.Type)" />
                    <PropertyColumn Title="Severity" Property="@(m => m.Severity)" />
                    <PropertyColumn Title="Description" Property="@(m => m.Description)" />
                </FluentDataGrid>
            }
            else
            {
                <EmptyStatePanel
                    Title="No exceptions in this run"
                    Message="A clean run means all compared billing lines matched within tolerance. You can still review margin lines and send proposals to approval if changes were suggested."
                    ActionHref="/reconciliation"
                    ActionLabel="Run another reconciliation" />
            }
        </FluentTab>
        <FluentTab Header="Audit">
            @if (_auditEvents.Count == 0)
            {
                <EmptyStatePanel
                    Title="No audit events"
                    Message="Audit events are recorded when proposals are approved, rejected, or exported. Complete the approval workflow to build an audit trail for this run."
                    ActionHref="@($"/approvals/{RunId}")"
                    ActionLabel="Open approval queue" />
            }
            else
            {
                <FluentDataGrid Items="@_auditEvents.AsQueryable()" GridTemplateColumns="1fr 2fr">
                    <PropertyColumn Title="Time" Property="@(e => e.Timestamp)" Format="g" />
                    <PropertyColumn Title="Summary" Property="@(e => e.Summary)" />
                </FluentDataGrid>
            }
        </FluentTab>
    </FluentTabs>
}

@code {
    [Parameter] public Guid RunId { get; set; }

    private RunDetailViewModel? _detail;
    private IReadOnlyList<RunHistoryAuditEvent> _auditEvents = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _detail = await ApiClient.GetRunDetailAsync(RunId, includeResults: true);
            var audit = await ApiClient.GetAuditEventsAsync(RunId);
            _auditEvents = audit.Events;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task IngestProposalsAsync()
    {
        await ApprovalClient.IngestFromRunAsync(RunId);
        Navigation.NavigateTo($"/approvals/{RunId}");
    }
}

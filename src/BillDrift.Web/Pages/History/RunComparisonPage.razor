@page "/history/compare"
@rendermode InteractiveServer
@using BillDrift.Application.History
@using BillDrift.Domain.History
@using BillDrift.Domain.Reconciliation
@inject IRunHistoryApiClient ApiClient

<PageTitle>Compare Runs</PageTitle>

<h1>Compare Runs</h1>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentSelect TOption="string" TValue="string" @bind-Value="_earlierRunId" Label="Earlier run">
        <FluentOption TOption="string" TValue="string" Value="@NoneValue">Select run</FluentOption>
        @foreach (var run in _runs)
        {
            <FluentOption TOption="string" TValue="string" Value="@run.RunId.Value.ToString()">@run.CompletedAt:g — @run.RunId.Value</FluentOption>
        }
    </FluentSelect>
    <FluentSelect TOption="string" TValue="string" @bind-Value="_laterRunId" Label="Later run">
        <FluentOption TOption="string" TValue="string" Value="@NoneValue">Select run</FluentOption>
        @foreach (var run in _runs)
        {
            <FluentOption TOption="string" TValue="string" Value="@run.RunId.Value.ToString()">@run.CompletedAt:g — @run.RunId.Value</FluentOption>
        }
    </FluentSelect>
    <FluentButton Appearance="ButtonAppearance.Primary" OnClick="CompareAsync">Compare</FluentButton>
</FluentStack>

@if (_report is not null)
{
  @if (_report.MappingVersionChanged)
  {
    <FluentMessageBar Intent="MessageBarIntent.Warning">Mapping version changed between runs.</FluentMessageBar>
  }

  <FluentAccordion>
    <FluentAccordionItem Heading="New Exceptions" Expanded="true">
      <p>@_report.ExceptionDeltas.NewExceptions.Count new exception(s)</p>
    </FluentAccordionItem>
    <FluentAccordionItem Heading="Resolved Exceptions">
      <p>@_report.ExceptionDeltas.ResolvedExceptions.Count resolved exception(s)</p>
    </FluentAccordionItem>
    <FluentAccordionItem Heading="Persisting Exceptions">
      <p>@_report.ExceptionDeltas.PersistingExceptions.Count persisting exception(s)</p>
    </FluentAccordionItem>
  </FluentAccordion>
}

@code {
    private const string NoneValue = "__none__";
    private string _earlierRunId = NoneValue;
    private string _laterRunId = NoneValue;
    private RunComparisonReport? _report;
    private IReadOnlyList<RunHistoryListItem> _runs = [];

    protected override async Task OnInitializedAsync()
    {
        var response = await ApiClient.ListRunsAsync(new RunHistoryListFilter(IncludeArchived: true));
        _runs = response.Items;
    }

    private async Task CompareAsync()
    {
        if (_earlierRunId == NoneValue || _laterRunId == NoneValue)
        {
            return;
        }

        _report = await ApiClient.CompareRunsAsync(new CompareRunsRequest(
            RunId.FromGuid(Guid.Parse(_earlierRunId)),
            RunId.FromGuid(Guid.Parse(_laterRunId))));
    }
}
